[mysqld]
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci
default-time-zone=+08:00
default-authentication-plugin=mysql_native_password
sql_mode=STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION
max_connections=300

# Local development credentials.
# MySQL server initialization still uses Docker ENV in deploy/mysql/Dockerfile
# or docker-compose.mysql.yml. Keep these values local only.
# root password: xj_root_123456
# app database: xj_comp
# app user: xj_app
# app password: xj_app_123456

[client]
default-character-set=utf8mb4

[mysql]
default-character-set=utf8mb4
database=xj_comp
