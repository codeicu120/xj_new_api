# App
APP_ENV=dev
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
LOG_LEVEL=info
SHUTDOWN_TIMEOUT=10s
CORS_ORIGINS=*
TRUSTED_PROXIES=

# MySQL
# Local Docker MySQL default:
MYSQL_DSN=xj_app:xj_app_123456@tcp(127.0.0.1:3306)/xj_comp?charset=utf8mb4&parseTime=true&loc=Local
# Optional read replica corresponding to PHP init.db3. Empty falls back to MYSQL_DSN.
MYSQL_READ_DSN=
# Optional separate legacy log database used by minivod request queues.
# Leave empty only when these tables are in MYSQL_DSN's database.
MYSQL_LOG_DSN=
# External MySQL example:
# MYSQL_DSN=xj_app:your_password@tcp(mysql.example.com:3306)/xj_comp?charset=utf8mb4&parseTime=true&loc=Local

# Redis
# Leave REDIS_ADDR empty to disable Redis locally.
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# Resources
RESOURCE_BASE_URL=https://aqsmimg365.sbs:10002
GAME_RESOURCE_BASE_URL=https://image.xjdev.one
UPLOAD_PATH=/Users/canavs/xjProj/XJBackend/api/res
IPDB_PATH=/Users/canavs/xjProj/XJBackend/api/data/ipipfree.ipdb

# Feature switches
SMS_CAPTCHA=1
CAPTCHA_STYLE=0
VIP_DISCOUNT=50

# AI undress external provider.
# Keep real keys in local .env only.
AIUNDRESS_THIRD_HOST=
AIUNDRESS_THIRD_KEY=

# AI undress Cloudflare R2 upload.
# Leave empty for local-only upload simulation.
AIUNDRESS_R2_ACCOUNT_ID=
AIUNDRESS_R2_ACCESS_KEY=
AIUNDRESS_R2_SECRET_KEY=
AIUNDRESS_R2_BUCKET=
AIUNDRESS_R2_TIMEOUT=60s

# Respond provider secrets.
# Keep real secrets in local .env only.
RESPOND_SHANGFU_APP_SECRET=
RESPOND_PAY7_SECRET=
